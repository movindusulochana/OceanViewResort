<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="520.0" prefWidth="850.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- TITLE -->
    <top>
        <HBox alignment="CENTER">
            <padding>
                <Insets top="15" bottom="15"/>
            </padding>
            <children>
                <Label text="Billing Management">
                    <font>
                        <Font name="System Bold" size="22"/>
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <!-- LEFT FORM -->
    <left>
        <VBox spacing="14" prefWidth="320">
            <padding>
                <Insets top="15" left="25" right="25" bottom="25"/>
            </padding>

            <children>

                <Label text="Bill ID"/>
                <TextField fx:id="billIdField"/>

                <Label text="Guest Name"/>
                <TextField fx:id="guestNameField"/>

                <Label text="Room Number"/>
                <TextField fx:id="roomNumberField"/>

                <Label text="Room Charges"/>
                <TextField fx:id="roomChargesField"/>

                <Label text="Extra Services"/>
                <TextField fx:id="extraServicesField"/>

                <Label text="Total Amount"/>
                <TextField fx:id="totalAmountField" editable="false"/>

                <Label text="Payment Method"/>
                <ComboBox fx:id="paymentMethodBox"/>

                <!-- BUTTON ROW -->
                <HBox spacing="12" alignment="CENTER">
                    <children>

                        <Button text="Calculate"
                                prefWidth="90"
                                style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-background-radius: 15;"/>

                        <Button text="Print"
                                prefWidth="80"
                                style="-fx-background-color: #388e3c; -fx-text-fill: white; -fx-background-radius: 15;"/>

                        <Button text="Clear"
                                prefWidth="80"
                                style="-fx-background-color: gray; -fx-text-fill: white; -fx-background-radius: 15;"/>

                    </children>
                </HBox>

            </children>
        </VBox>
    </left>

    <!-- TABLE -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="20" bottom="20"/>
            </padding>

            <children>

                <TableView fx:id="billingTable">

                    <columns>
                        <TableColumn text="Bill ID" prefWidth="80"/>
                        <TableColumn text="Guest Name" prefWidth="120"/>
                        <TableColumn text="Room No" prefWidth="80"/>
                        <TableColumn text="Charges" prefWidth="90"/>
                        <TableColumn text="Extras" prefWidth="90"/>
                        <TableColumn text="Total" prefWidth="90"/>
                        <TableColumn text="Payment" prefWidth="100"/>
                    </columns>

                </TableView>

            </children>
        </VBox>
    </center>

</BorderPane>