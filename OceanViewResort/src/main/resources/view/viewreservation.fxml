<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<BorderPane prefHeight="650.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oceanview.resort.controller.ViewReservationController">

    <left>
        <VBox prefWidth="240.0" prefHeight="650.0" spacing="0.0"
              style="-fx-background-color: linear-gradient(to bottom, #016a8a, #005b96);">

            <VBox alignment="CENTER" spacing="12.0">
                <padding><Insets top="30.0" bottom="20.0" left="20.0" right="20.0"/></padding>
                <children>
                    <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
                                minHeight="-Infinity" minWidth="-Infinity"
                                prefHeight="90.0" prefWidth="90.0">
                        <children>
                            <ImageView fx:id="sidebarLogoView" fitHeight="90.0" fitWidth="90.0"
                                       pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@../resource/icon.jpeg" /></image>
                                <clip><Circle centerX="45.0" centerY="45.0" radius="45.0" /></clip>
                                <effect><DropShadow color="#003366" radius="8" offsetX="2" offsetY="2"/></effect>
                            </ImageView>
                        </children>
                    </AnchorPane>
                    <Label text="OCEAN VIEW" textFill="WHITE">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                    <Label text="RESORT" textFill="WHITE">
                        <font><Font size="13.0" /></font>
                    </Label>
                </children>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.3);">
                <padding><Insets left="20.0" right="20.0"/></padding>
            </Separator>

            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="20.0" left="15.0" right="15.0"/></padding>
                <children>
                    <Label text="MAIN MENU" textFill="rgba(255,255,255,0.6)">
                        <font><Font name="System Bold" size="10.0" /></font>
                        <padding><Insets left="10.0" bottom="5.0"/></padding>
                    </Label>
                    <Button fx:id="navDashboardBtn" mnemonicParsing="false" onAction="#goToDashboard"
                            prefHeight="42.0" prefWidth="210.0" text="  🏠   Dashboard"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                    <Button fx:id="navNewReservationBtn" mnemonicParsing="false" onAction="#showNewReservation"
                            prefHeight="42.0" prefWidth="210.0" text="  ➕   New Reservation"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                    <Button fx:id="navViewReservationsBtn" mnemonicParsing="false" onAction="#showViewReservations"
                            prefHeight="42.0" prefWidth="210.0" text="  📋   View Reservations"
                            style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="navBillingBtn" mnemonicParsing="false" onAction="#showBilling"
                            prefHeight="42.0" prefWidth="210.0" text="  💳   Billing"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                    <Button fx:id="navGuestsBtn" mnemonicParsing="false" onAction="#showGuests"
                            prefHeight="42.0" prefWidth="210.0" text="  👤   Guest Management"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                    <Label text="SYSTEM" textFill="rgba(255,255,255,0.6)">
                        <font><Font name="System Bold" size="10.0" /></font>
                        <padding><Insets left="10.0" top="15.0" bottom="5.0"/></padding>
                    </Label>
                    <Button fx:id="navHelpBtn" mnemonicParsing="false" onAction="#showHelp"
                            prefHeight="42.0" prefWidth="210.0" text="  ❓   Help"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                    <Button fx:id="navLogoutBtn" mnemonicParsing="false" onAction="#handleLogout"
                            prefHeight="42.0" prefWidth="210.0" text="  🚪   Logout"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                </children>
            </VBox>

            <VBox alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(0,0,0,0.2); -fx-background-radius: 10;">
                <padding><Insets top="12.0" bottom="12.0" left="15.0" right="15.0"/></padding>
                <VBox.margin><Insets bottom="15.0" left="15.0" right="15.0"/></VBox.margin>
                <children>
                    <Label text="Logged in as" textFill="rgba(255,255,255,0.6)">
                        <font><Font size="10.0" /></font>
                    </Label>
                    <Label fx:id="loggedInUserLabel" text="Staff Member" textFill="WHITE">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                </children>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0.0" style="-fx-background-color: #f0f4f8;">

            <HBox prefHeight="65.0" alignment="CENTER_LEFT" spacing="15.0"
                  style="-fx-background-color: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">
                <padding><Insets left="30.0" right="30.0"/></padding>
                <children>
                    <Label text="View Reservations" textFill="#333333">
                        <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                    <HBox HBox.hgrow="ALWAYS" />
                    <Label fx:id="currentDateLabel" text="" textFill="#888888">
                        <font><Font size="13.0" /></font>
                    </Label>
                </children>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <content>
                    <VBox spacing="20.0">
                        <padding><Insets top="25.0" bottom="30.0" left="25.0" right="25.0"/></padding>
                        <children>

                            <VBox spacing="14.0"
                                  style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <padding><Insets top="20.0" bottom="20.0" left="24.0" right="24.0"/></padding>
                                <children>
                                    <Label text="Search and Filter" textFill="#333333">
                                        <font><Font name="System Bold" size="14.0" /></font>
                                    </Label>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <children>
                                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Search" textFill="#666666">
                                                        <font><Font size="11.0" /></font>
                                                    </Label>
                                                    <TextField fx:id="searchField" prefHeight="38.0"
                                                               promptText="Reservation No. or Guest Name"
                                                               style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="5.0" prefWidth="160.0">
                                                <children>
                                                    <Label text="Room Type" textFill="#666666">
                                                        <font><Font size="11.0" /></font>
                                                    </Label>
                                                    <ComboBox fx:id="filterRoomTypeComboBox"
                                                              prefHeight="38.0" prefWidth="160.0"
                                                              promptText="All Types"
                                                              style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="5.0" prefWidth="150.0">
                                                <children>
                                                    <Label text="Status" textFill="#666666">
                                                        <font><Font size="11.0" /></font>
                                                    </Label>
                                                    <ComboBox fx:id="filterStatusComboBox"
                                                              prefHeight="38.0" prefWidth="150.0"
                                                              promptText="All Statuses"
                                                              style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="5.0" alignment="BOTTOM_LEFT">
                                                <children>
                                                    <HBox spacing="10.0">
                                                        <children>
                                                            <Button fx:id="searchBtn" mnemonicParsing="false"
                                                                    onAction="#handleSearch"
                                                                    prefHeight="38.0" prefWidth="100.0" text="Search"
                                                                    style="-fx-background-color: #005b96; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;">
                                                                <font><Font name="System Bold" size="12.0" /></font>
                                                            </Button>
                                                            <Button fx:id="clearSearchBtn" mnemonicParsing="false"
                                                                    onAction="#handleClearSearch"
                                                                    prefHeight="38.0" prefWidth="80.0" text="Clear"
                                                                    style="-fx-background-color: transparent; -fx-text-fill: #005b96; -fx-border-color: #005b96; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;">
                                                                <font><Font size="12.0" /></font>
                                                            </Button>
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <VBox spacing="0.0"
                                  style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <padding><Insets top="20.0" bottom="20.0" left="24.0" right="24.0"/></padding>
                                <children>

                                    <HBox prefHeight="38.0" alignment="CENTER_LEFT"
                                          style="-fx-background-color: #f0f4f8; -fx-background-radius: 8;">
                                        <padding><Insets left="12.0" right="12.0"/></padding>
                                        <children>
                                            <Label text="Res. No." textFill="#555555" prefWidth="90.0">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                            <Label text="Guest ID" textFill="#555555" prefWidth="160.0">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                            <Label text="Room" textFill="#555555" prefWidth="130.0">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                            <Label text="Check-In" textFill="#555555" prefWidth="110.0">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                            <Label text="Check-Out" textFill="#555555" prefWidth="110.0">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                            <Label text="Status" textFill="#555555" prefWidth="110.0">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                            <Label text="Actions" textFill="#555555" HBox.hgrow="ALWAYS">
                                                <font><Font name="System Bold" size="11.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>

                                    <VBox fx:id="reservationsTableContainer" spacing="2.0">
                                        <padding><Insets top="5.0"/></padding>
                                    </VBox>

                                    <VBox fx:id="emptyStateBox" alignment="CENTER" spacing="10.0" prefHeight="160.0" visible="false" managed="false">
                                        <padding><Insets top="30.0" bottom="10.0"/></padding>
                                        <children>
                                            <Label text="No reservations found." textFill="#aaaaaa">
                                                <font><Font size="14.0" /></font>
                                            </Label>
                                            <Label text="Try adjusting your search filters or add a new reservation."
                                                   textFill="#cccccc" wrapText="true">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                <children>
                                    <Label fx:id="resultsCountLabel" text="Showing 0 reservations"
                                           textFill="#888888" HBox.hgrow="ALWAYS">
                                        <font><Font size="12.0" /></font>
                                    </Label>
                                    <Button fx:id="prevPageBtn" mnemonicParsing="false"
                                            onAction="#handlePrevPage"
                                            prefHeight="34.0" prefWidth="90.0" text="Prev"
                                            style="-fx-background-color: transparent; -fx-text-fill: #005b96; -fx-border-color: #005b96; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;">
                                        <font><Font size="12.0" /></font>
                                    </Button>
                                    <Label fx:id="pageIndicatorLabel" text="Page 1" textFill="#555555">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Label>
                                    <Button fx:id="nextPageBtn" mnemonicParsing="false"
                                            onAction="#handleNextPage"
                                            prefHeight="34.0" prefWidth="90.0" text="Next"
                                            style="-fx-background-color: #005b96; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;">
                                        <font><Font size="12.0" /></font>
                                    </Button>
                                </children>
                            </HBox>

                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>

    <right>
        <VBox fx:id="detailPanel" prefWidth="300.0" spacing="0.0" visible="false" managed="false"
              style="-fx-background-color: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 10, 0, -3, 0);">

            <HBox prefHeight="55.0" alignment="CENTER_LEFT" spacing="10.0"
                  style="-fx-background-color: linear-gradient(to right, #016a8a, #005b96);">
                <padding><Insets left="18.0" right="12.0"/></padding>
                <children>
                    <Label text="Reservation Detail" textFill="WHITE">
                        <font><Font name="System Bold" size="14.0" /></font>
                    </Label>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button fx:id="closeDetailPanelBtn" mnemonicParsing="false"
                            onAction="#handleCloseDetailPanel" text="X"
                            style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;"/>
                </children>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <content>
                    <VBox spacing="14.0">
                        <padding><Insets top="20.0" bottom="20.0" left="18.0" right="18.0"/></padding>
                        <children>

                            <HBox alignment="CENTER">
                                <children>
                                    <Label fx:id="detailResNoLabel" text="RES-0000"
                                           style="-fx-background-color: #e8f0fe; -fx-background-radius: 20; -fx-text-fill: #005b96; -fx-padding: 6 16 6 16;">
                                        <font><Font name="System Bold" size="14.0" /></font>
                                    </Label>
                                </children>
                            </HBox>

                            <Separator style="-fx-background-color: #e0e8f0;"/>

                            <Label text="GUEST INFORMATION" textFill="#888888">
                                <font><Font name="System Bold" size="10.0" /></font>
                            </Label>
                            <VBox spacing="10.0">
                                <children>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Name" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailGuestNameLabel" text="--" textFill="#333333" wrapText="true">
                                                <font><Font name="System Bold" size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Address" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailAddressLabel" text="--" textFill="#333333" wrapText="true">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Contact" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailContactLabel" text="--" textFill="#333333">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <Separator style="-fx-background-color: #e0e8f0;"/>

                            <Label text="STAY INFORMATION" textFill="#888888">
                                <font><Font name="System Bold" size="10.0" /></font>
                            </Label>
                            <VBox spacing="10.0">
                                <children>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Room Type" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailRoomTypeLabel" text="--" textFill="#333333">
                                                <font><Font name="System Bold" size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Check-In" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailCheckInLabel" text="--" textFill="#333333">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Check-Out" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailCheckOutLabel" text="--" textFill="#333333">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Nights" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailNightsLabel" text="--" textFill="#333333">
                                                <font><Font name="System Bold" size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                    <HBox spacing="8.0">
                                        <children>
                                            <Label text="Status" textFill="#888888" prefWidth="90.0">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <Label fx:id="detailStatusLabel" text="--" textFill="#2e7d32">
                                                <font><Font name="System Bold" size="12.0" /></font>
                                            </Label>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <Separator style="-fx-background-color: #e0e8f0;"/>

                            <Label text="BILLING SUMMARY" textFill="#888888">
                                <font><Font name="System Bold" size="10.0" /></font>
                            </Label>
                            <HBox alignment="CENTER_LEFT" spacing="0.0"
                                  style="-fx-background-color: #f0f4f8; -fx-background-radius: 10;">
                                <padding><Insets top="12.0" bottom="12.0" left="14.0" right="14.0"/></padding>
                                <children>
                                    <Label text="Total Amount" textFill="#555555" HBox.hgrow="ALWAYS">
                                        <font><Font size="13.0" /></font>
                                    </Label>
                                    <Label fx:id="detailTotalLabel" text="--" textFill="#005b96">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Label>
                                </children>
                            </HBox>

                            <Label text="SPECIAL REQUESTS" textFill="#888888">
                                <font><Font name="System Bold" size="10.0" /></font>
                            </Label>
                            <Label fx:id="detailSpecialRequestsLabel" text="None" textFill="#555555" wrapText="true">
                                <font><Font size="12.0" /></font>
                            </Label>

                            <Separator style="-fx-background-color: #e0e8f0;"/>

                            <VBox spacing="10.0">
                                <children>
                                    <Button fx:id="detailCalculateBillBtn" mnemonicParsing="false"
                                            onAction="#handleDetailCalculateBill"
                                            prefHeight="38.0" prefWidth="9999.0" text="Calculate Bill"
                                            style="-fx-background-color: #005b96; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Button>
                                    <Button fx:id="detailEditBtn" mnemonicParsing="false"
                                            onAction="#handleDetailEdit"
                                            prefHeight="38.0" prefWidth="9999.0" text="Edit Reservation"
                                            style="-fx-background-color: transparent; -fx-text-fill: #005b96; -fx-border-color: #005b96; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;">
                                        <font><Font size="12.0" /></font>
                                    </Button>
                                    <Button fx:id="detailDeleteBtn" mnemonicParsing="false"
                                            onAction="#handleDetailDelete"
                                            prefHeight="38.0" prefWidth="9999.0" text="Delete Reservation"
                                            style="-fx-background-color: transparent; -fx-text-fill: #c62828; -fx-border-color: #c62828; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;">
                                        <font><Font size="12.0" /></font>
                                    </Button>
                                </children>
                            </VBox>

                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </right>

</BorderPane>