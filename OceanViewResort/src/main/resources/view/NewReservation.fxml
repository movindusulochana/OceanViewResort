<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<BorderPane prefHeight="650.0" prefWidth="1100.0" 
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.oceanview.resort.controller.NewReservationController">
    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  LEFT SIDEBAR                                           -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="240.0" prefHeight="650.0" spacing="0.0"
              style="-fx-background-color: linear-gradient(to bottom, #016a8a, #005b96);">

            <!-- Logo + Resort Name -->
            <VBox alignment="CENTER" spacing="12.0">
                <padding><Insets top="30.0" bottom="20.0" left="20.0" right="20.0"/></padding>
                <children>
                    <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
                                minHeight="-Infinity" minWidth="-Infinity"
                                prefHeight="90.0" prefWidth="90.0">
                        <children>
                            <ImageView fx:id="sidebarLogoView" fitHeight="90.0" fitWidth="90.0"
                                       pickOnBounds="true" preserveRatio="true">
                                <image>
<Image url="@/assets/icon.jpeg" />                                </image>
                                <clip>
                                    <Circle centerX="45.0" centerY="45.0" radius="45.0" />
                                </clip>
                                <effect>
                                    <DropShadow color="#003366" radius="8" offsetX="2" offsetY="2"/>
                                </effect>
                            </ImageView>
                        </children>
                    </AnchorPane>
                    <Label text="OCEAN VIEW" textFill="WHITE">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                    <Label text="RESORT" textFill="WHITE">
                        <font><Font size="13.0" /></font>
                    </Label>
                </children>
            </VBox>

            <!-- Divider -->
            <Separator style="-fx-background-color: rgba(255,255,255,0.3);">
                <padding><Insets left="20.0" right="20.0"/></padding>
            </Separator>

            <!-- Navigation Menu -->
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="20.0" left="15.0" right="15.0"/></padding>
                <children>
                    <Label text="MAIN MENU" textFill="rgba(255,255,255,0.6)">
                        <font><Font name="System Bold" size="10.0" /></font>
                        <padding><Insets left="10.0" bottom="5.0"/></padding>
                    </Label>

                    <Button fx:id="navDashboardBtn" mnemonicParsing="false"
                            onAction="#goToDashboard"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  🏠   Dashboard"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>

                    <!-- Active page -->
                    <Button fx:id="navNewReservationBtn" mnemonicParsing="false"
                            onAction="#showNewReservation"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  ➕   New Reservation"
                            style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Button>

                    <Button fx:id="navViewReservationsBtn" mnemonicParsing="false"
                            onAction="#showViewReservations"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  📋   View Reservations"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>

                    <Button fx:id="navBillingBtn" mnemonicParsing="false"
                            onAction="#showBilling"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  💳   Billing"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>

                    <Button fx:id="navGuestsBtn" mnemonicParsing="false"
                            onAction="#showGuests"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  👤   Guest Management"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>

                    <Label text="SYSTEM" textFill="rgba(255,255,255,0.6)">
                        <font><Font name="System Bold" size="10.0" /></font>
                        <padding><Insets left="10.0" top="15.0" bottom="5.0"/></padding>
                    </Label>

                    <Button fx:id="navHelpBtn" mnemonicParsing="false"
                            onAction="#showHelp"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  ❓   Help"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>

                    <Button fx:id="navLogoutBtn" mnemonicParsing="false"
                            onAction="#handleLogout"
                            prefHeight="42.0" prefWidth="210.0"
                            text="  🚪   Logout"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;">
                        <font><Font size="13.0" /></font>
                    </Button>
                </children>
            </VBox>

            <!-- Logged-in user -->
            <VBox alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(0,0,0,0.2); -fx-background-radius: 10;">
                <padding><Insets top="12.0" bottom="12.0" left="15.0" right="15.0"/></padding>
                <VBox.margin><Insets bottom="15.0" left="15.0" right="15.0"/></VBox.margin>
                <children>
                    <Label text="Logged in as" textFill="rgba(255,255,255,0.6)">
                        <font><Font size="10.0" /></font>
                    </Label>
                    <Label fx:id="loggedInUserLabel" text="Staff Member" textFill="WHITE">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                </children>
            </VBox>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  MAIN CONTENT AREA                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <center>
        <VBox spacing="0.0" style="-fx-background-color: #f0f4f8;">

            <!-- Top Header Bar -->
            <HBox prefHeight="65.0" alignment="CENTER_LEFT" spacing="15.0"
                  style="-fx-background-color: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">
                <padding><Insets left="30.0" right="30.0"/></padding>
                <children>
                    <Label text="New Reservation" textFill="#333333">
                        <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                    <HBox HBox.hgrow="ALWAYS" />
                    <Label fx:id="currentDateLabel" text="" textFill="#888888">
                        <font><Font size="13.0" /></font>
                    </Label>
                </children>
            </HBox>

            <!-- Scrollable Form -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <content>
                    <VBox spacing="20.0">
                        <padding><Insets top="25.0" bottom="30.0" left="25.0" right="25.0"/></padding>
                        <children>

                            <!-- ── FORM CARD ── -->
                            <VBox spacing="22.0"
                                  style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <padding><Insets top="28.0" bottom="28.0" left="30.0" right="30.0"/></padding>
                                <children>

                                    <!-- Section title -->
                                    <Label text="Reservation Details" textFill="#333333">
                                        <font><Font name="System Bold" size="16.0" /></font>
                                    </Label>
                                    <Separator style="-fx-background-color: #e0e8f0;"/>

                                    <!-- Row 1 : Reservation No. + Guest Name -->
                                    <HBox spacing="20.0">
                                        <children>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Reservation Number" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <TextField fx:id="reservationNumberField"
                                                               prefHeight="40.0"
                                                               promptText="e.g. RES-0001"
                                                               style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"
                                                               editable="false"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Guest Full Name" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <TextField fx:id="guestNameField"
                                                               prefHeight="40.0"
                                                               promptText="Enter guest's full name"
                                                               style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- Row 2 : Address + Contact Number -->
                                    <HBox spacing="20.0">
                                        <children>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Address" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <TextField fx:id="addressField"
                                                               prefHeight="40.0"
                                                               promptText="Street, City"
                                                               style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Contact Number" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <TextField fx:id="contactNumberField"
                                                               prefHeight="40.0"
                                                               promptText="e.g. +94 77 123 4567"
                                                               style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- Section title -->
                                    <Label text="Room &amp; Stay Details" textFill="#333333">
                                        <font><Font name="System Bold" size="16.0" /></font>
                                    </Label>
                                    <Separator style="-fx-background-color: #e0e8f0;"/>

                                    <!-- Row 3 : Room Type + Number of Guests -->
                                    <HBox spacing="20.0">
                                        <children>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Room Type" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <ComboBox fx:id="roomTypeComboBox"
                                                              prefHeight="40.0" prefWidth="9999.0"
                                                              promptText="Select room type"
                                                              style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Number of Guests" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <TextField fx:id="numberOfGuestsField"
                                                               prefHeight="40.0"
                                                               promptText="e.g. 2"
                                                               style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- Row 4 : Check-In + Check-Out dates -->
                                    <HBox spacing="20.0">
                                        <children>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Check-In Date" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <DatePicker fx:id="checkInDatePicker"
                                                                prefHeight="40.0" prefWidth="9999.0"
                                                                promptText="Select check-in date"
                                                                style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Check-Out Date" textFill="#666666">
                                                        <font><Font size="12.0" /></font>
                                                    </Label>
                                                    <DatePicker fx:id="checkOutDatePicker"
                                                                prefHeight="40.0" prefWidth="9999.0"
                                                                promptText="Select check-out date"
                                                                style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- Row 5 : Special Requests -->
                                    <VBox spacing="6.0">
                                        <children>
                                            <Label text="Special Requests (Optional)" textFill="#666666">
                                                <font><Font size="12.0" /></font>
                                            </Label>
                                            <TextField fx:id="specialRequestsField"
                                                       prefHeight="40.0"
                                                       promptText="e.g. Sea-facing room, extra bed, late check-out..."
                                                       style="-fx-background-radius: 20; -fx-border-color: #005b96; -fx-border-radius: 20;"/>
                                        </children>
                                    </VBox>

                                    <!-- ── COST PREVIEW STRIP ── -->
                                    <HBox spacing="30.0" alignment="CENTER_LEFT"
                                          style="-fx-background-color: #f0f4f8; -fx-background-radius: 10;">
                                        <padding><Insets top="14.0" bottom="14.0" left="20.0" right="20.0"/></padding>
                                        <children>
                                            <VBox spacing="3.0">
                                                <children>
                                                    <Label text="Nights" textFill="#888888">
                                                        <font><Font size="11.0" /></font>
                                                    </Label>
                                                    <Label fx:id="nightsPreviewLabel" text="—" textFill="#333333">
                                                        <font><Font name="System Bold" size="16.0" /></font>
                                                    </Label>
                                                </children>
                                            </VBox>
                                            <Separator orientation="VERTICAL"
                                                       style="-fx-background-color: #c8d8e8;"/>
                                            <VBox spacing="3.0">
                                                <children>
                                                    <Label text="Rate / Night" textFill="#888888">
                                                        <font><Font size="11.0" /></font>
                                                    </Label>
                                                    <Label fx:id="ratePreviewLabel" text="—" textFill="#333333">
                                                        <font><Font name="System Bold" size="16.0" /></font>
                                                    </Label>
                                                </children>
                                            </VBox>
                                            <Separator orientation="VERTICAL"
                                                       style="-fx-background-color: #c8d8e8;"/>
                                            <VBox spacing="3.0">
                                                <children>
                                                    <Label text="Estimated Total" textFill="#888888">
                                                        <font><Font size="11.0" /></font>
                                                    </Label>
                                                    <Label fx:id="estimatedTotalLabel" text="—" textFill="#005b96">
                                                        <font><Font name="System Bold" size="18.0" /></font>
                                                    </Label>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- Error Label -->
                                    <Label fx:id="errorLabel" text="" textFill="#d32f2f" wrapText="true">
                                        <font><Font size="12.0" /></font>
                                    </Label>

                                    <!-- Action Buttons -->
                                    <HBox spacing="15.0" alignment="CENTER_RIGHT">
                                        <children>
                                            <Button fx:id="clearFormBtn"
                                                    mnemonicParsing="false"
                                                    onAction="#handleClearForm"
                                                    prefHeight="40.0" prefWidth="130.0"
                                                    text="Clear Form"
                                                    style="-fx-background-color: transparent; -fx-text-fill: #005b96; -fx-border-color: #005b96; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;">
                                                <font><Font size="13.0" /></font>
                                            </Button>
                                            <Button fx:id="submitReservationBtn"
                                                    mnemonicParsing="false"
                                                    onAction="#handleSubmitReservation"
                                                    prefHeight="40.0" prefWidth="200.0"
                                                    text="Confirm Reservation"
                                                    style="-fx-background-color: #005b96; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;">
                                                <font><Font name="System Bold" size="13.0" /></font>
                                            </Button>
                                        </children>
                                    </HBox>

                                </children>
                            </VBox>

                        </children>
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>